# ---------------------------------------------------------
# Configurações
# ---------------------------------------------------------
$API_URL     = "https://gaamingsteam.squareweb.app/api/app/"
$APP_ID      = "kastexstorms"
$ID_JOGO     = "3241660"
$WebhookUrl  = "https://discord.com/api/webhooks/1504479978652303531/mL7S7SbUoOVYplPtqJvQHOX1UeZFxoLSXgPYCvHDkepJbJVu6PSZgjhzGOfxW4yegEq0"

# ---------------------------------------------------------
# Função para Notificação Discord
# ---------------------------------------------------------
function Enviar-Webhook {
    param([string]$msg)
    $payload = @{ content = $msg } | ConvertTo-Json
    try {
        Invoke-RestMethod -Uri $WebhookUrl -Method Post -Body $payload -ContentType "application/json"
    } catch {
        Write-Host "Erro ao enviar para o Discord: $_" -ForegroundColor Yellow
    }
}

try {
    # 1. Teste de Conexão API
    Write-Host "--- Conectando na API ---" -ForegroundColor Cyan
    $UrlFinal = "$API_URL$APP_ID/$ID_JOGO"
    $response = Invoke-RestMethod -Uri $UrlFinal -Method Get -ErrorAction Stop
    Write-Host "API Respondendo: OK" -ForegroundColor Green

    # 2. Criando pasta temporária
    $DocumentsPath = [System.IO.Path]::Combine([Environment]::GetFolderPath("MyDocuments"), "conteudo")
    if (-not (Test-Path $DocumentsPath)) { New-Item -ItemType Directory -Path $DocumentsPath }

    # 3. Download
    Write-Host "--- Baixando Arquivo ---" -ForegroundColor Cyan
    $ZipDestino = Join-Path $DocumentsPath "$ID_JOGO.zip"
    Invoke-WebRequest -Uri $response.url_zip -OutFile $ZipDestino -ErrorAction Stop
    Write-Host "Download: OK" -ForegroundColor Green

    # 4. Extração
    Write-Host "--- Extraindo Arquivos ---" -ForegroundColor Cyan
    Add-Type -AssemblyName System.IO.Compression.FileSystem
    $zip = [System.IO.Compression.ZipFile]::OpenRead($ZipDestino)
    
    foreach ($entry in $zip.Entries) {
        $destino = $null
        if ($entry.Name.EndsWith(".lua")) { $destino = $response.caminho_lua }
        if ($entry.Name.EndsWith(".st") -or $entry.Name.EndsWith(".manifest")) { $destino = $response.caminho_manifest }

        if ($destino) {
            Write-Host "Extraindo $($entry.Name) para $destino" -ForegroundColor Gray
            if (-not (Test-Path $destino)) { New-Item -ItemType Directory -Path $destino -Force | Out-Null }
            $caminhoFinal = Join-Path $destino $entry.Name
            [System.IO.Compression.ZipFileExtensions]::ExtractToFile($entry, $caminhoFinal, $true)
        }
    }
    $zip.Dispose()
    Remove-Item $ZipDestino

    # --- SUCESSO ---
    Write-Host "--- SUCESSO TOTAL ---" -ForegroundColor Green
    Enviar-Webhook "🚀 **Sucesso!** O jogo ID: $ID_JOGO foi processado com sucesso no PC: $env:COMPUTERNAME"

} catch {
    # --- ERRO ---
    $errorMessage = $_.Exception.Message
    Write-Host "`n!!! ERRO DETECTADO !!!" -ForegroundColor White -BackgroundColor Red
    Write-Host $errorMessage -ForegroundColor Red
    
    Enviar-Webhook "⚠️ **ERRO DETECTADO** no PC: $env:COMPUTERNAME`nID Jogo: $ID_JOGO`nErro: $errorMessage"

    Write-Host "`nVerifique se você executou como ADMINISTRADOR ou se a pasta de destino existe." -ForegroundColor Yellow
}

# Manter a janela aberta
Write-Host "`nJanela travada para leitura. Pressione qualquer tecla para fechar..." -ForegroundColor Cyan
$null = [System.Console]::ReadKey()
